#!/bin/bash

# ==========================================
# T4n IDE (Python + Zig) Installer for NvChad
# Installasi Zig & ZLS di /opt
# ==========================================

set -e  # Exit on error

# --- Colors ---
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# --- Helper Functions ---
log_info() { echo -e "${BLUE}[+] $1${NC}"; }
log_success() { echo -e "${GREEN}[✔] $1${NC}"; }
log_warn() { echo -e "${YELLOW}[!] $1${NC}"; }
log_error() { echo -e "${RED}[✗] $1${NC}"; exit 1; }

# Get Script Directory
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Check Root
if [ "$EUID" -eq 0 ]; then 
  log_error "Jangan jalankan script ini sebagai root. Gunakan user biasa (sudo akan diminta saat perlu)."
fi

# ==========================================
# 1. SYSTEM DEPENDENCIES
# ==========================================
log_info "T4n IDE (Python + Zig) Installer x86_64"

if ! command -v xbps-install &> /dev/null; then
  log_error "XBPS not found. Script ini hanya untuk Void Linux / T4n OS."
fi

log_info "Updating system packages..."
sudo xbps-install -Syu

log_info "Installing base packages..."
sudo xbps-install -y \
  git curl wget unzip \
  neovim nodejs \
  python3 python3-pip python3-virtualenv python3-devel \
  ripgrep fd tree-sitter tree-sitter-cli

# ==========================================
# 2. PYTHON SETUP
# ==========================================
log_info "Setting up Python environment..."

# Upgrade pip dan install tools python
python3 -m ensurepip --upgrade || true
pip3 install --user --upgrade pip
pip3 install --user pynvim ruff

log_info "Install UV - Package Manager..."
if ! command -v uv &> /dev/null; then
  curl -LsSf https://astral.sh/uv/install.sh | sh
fi

# ==========================================
# 3. ZIG SETUP (/opt/zig)
# ==========================================
ZIG_VERSION="0.16.0"
ZIG_INSTALL_DIR="/opt/zig"

log_info "Installing Zig ${ZIG_VERSION} to ${ZIG_INSTALL_DIR}..."

cd /tmp
# Download jika belum ada
if [ ! -f "zig-linux-x86_64-${ZIG_VERSION}.tar.xz" ]; then
  wget -q "https://ziglang.org/download/${ZIG_VERSION}/zig-linux-x86_64-${ZIG_VERSION}.tar.xz"
fi

# Hapus instalasi lama jika ada
sudo rm -rf "$ZIG_INSTALL_DIR"
sudo mkdir -p "$ZIG_INSTALL_DIR"

# Ekstrak dan salin ke /opt/zig
tar -xf "zig-linux-x86_64-${ZIG_VERSION}.tar.xz"
sudo cp -r "zig-linux-x86_64-${ZIG_VERSION}"/* "$ZIG_INSTALL_DIR/"

# Tambahkan PATH ke ~/.bashrc (aman & tidak duplikat)
if ! grep -q "$ZIG_INSTALL_DIR" "$HOME/.bashrc" 2>/dev/null; then
  echo "" >> "$HOME/.bashrc"
  echo "# T4n Zig PATH" >> "$HOME/.bashrc"
  echo "export PATH=\"$ZIG_INSTALL_DIR:\$PATH\"" >> "$HOME/.bashrc"
fi

# Verifikasi
if [ ! -f "$ZIG_INSTALL_DIR/zig" ]; then
  log_error "Gagal memasang Zig binary di $ZIG_INSTALL_DIR"
fi

# ==========================================
# 4. FONT INSTALLATION
# ==========================================
log_info "Installing FiraCode Nerd Font..."

FONT_DIR="$HOME/.fonts"
mkdir -p "$FONT_DIR"
cd "$FONT_DIR"

# Cek jika file zip sudah ada untuk hindari download ulang
if [ ! -f "FiraCode.zip" ]; then
  wget -q https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraCode.zip
fi

unzip -o -q FiraCode.zip
rm -f FiraCode.zip
fc-cache -fv > /dev/null

# ==========================================
# 5. NVCHAD CONFIGURATION
# ==========================================
log_info "Setting up NvChad configuration..."

# Cek apakah folder nvim ada di script directory
if [ ! -d "$PROJECT_DIR/nvim" ]; then
  log_error "Folder 'nvim' tidak ditemukan di '$PROJECT_DIR'. Pastikan struktur file benar."
fi

# Backup old config
TIMESTAMP=$(date +%s)
BACKUP_DIR="$HOME/.config/nvim.bak.$TIMESTAMP"
mv ~/.config/nvim "$BACKUP_DIR" 2>/dev/null || true
mv ~/.local/share/nvim "$BACKUP_DIR-data" 2>/dev/null || true

# Copy config baru
rm -rf ~/.config/nvim
cp -r "$PROJECT_DIR/nvim" ~/.config/nvim

# ==========================================
# 6. NEOVIM SYNC & PLUGINS
# ==========================================
log_info "Syncing Neovim plugins..."
nvim --headless "+Lazy sync" +qa

# ========================
# INSTALL LSP VIA MASON
# ========================
log_info "Installing LSP (pyright & zls) via Mason..."
nvim --headless "+MasonInstall ty zls" +qa || true

log_info "Installing Treesitter parsers (Python, Zig)..."
nvim --headless "+TSUpdateSync python zig" +qa || true

# ==========================================
# FINISH
# ==========================================
echo ""
log_success "Installation Complete!"
echo ""
log_warn "Struktur Installasi:"
echo "    Zig  : /opt/zig"
echo ""
log_warn "Silakan restart shell (terminal) Anda untuk memuat PATH baru:"
echo "    source ~/.bashrc   (jika pakai bash)"
echo "    source ~/.zshrc   (jika pakai zsh)"
echo ""
log_info "Kemudian buka nvim. Plugin akan otomatis selesai download."
